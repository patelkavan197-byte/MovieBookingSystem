CREATE DATABASE moviebooking;

USE moviebooking;

CREATE TABLE users(
id INT AUTO_INCREMENT PRIMARY KEY,
name VARCHAR(50),
email VARCHAR(50),
password VARCHAR(50)
);

CREATE TABLE movies(
id INT AUTO_INCREMENT PRIMARY KEY,
movie_name VARCHAR(50),
price INT
);

CREATE TABLE booking(
id INT AUTO_INCREMENT PRIMARY KEY,
user_email VARCHAR(50),
movie_name VARCHAR(50),
seat_no VARCHAR(10),
amount INT
);
